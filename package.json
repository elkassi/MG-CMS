  "scripts": {
    "start": "npm run watch",
    "build": "npm run prod",
    "test": "jest --runInBand",
    "watch": "webpack --watch --mode development",
    "prod": "webpack --mode production",
    "bundle:resources": "webpack --mode production --env outputDir=src/main/resources/static"
  },
  "proxy": "http://localhost:8085",
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "jest": {
    "roots": [
      "<rootDir>/src/main/js"
    ],
    "testMatch": [
      "**/*.test.js"
    ],
    "transform": {
      "^.+\\.[jt]sx?$": [
        "babel-jest",
        {
          "presets": [
            "@babel/preset-env",
            "@babel/preset-react"
          ],
          "plugins": [
            "@babel/plugin-proposal-class-properties",
            "@babel/plugin-transform-runtime"
          ]
        }
      ]
    },
    "testEnvironment": "node"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@babel/plugin-proposal-class-properties": "^7.18.6",
    "@babel/plugin-transform-runtime": "^7.26.0",
    "@babel/preset-env": "^7.26.0",
    "@babel/preset-react": "^7.26.3",
    "babel-jest": "^29.7.0",
    "babel-loader": "^9.2.1",
    "css-loader": "^5.2.4",
    "file-loader": "^6.2.0",
    "jest": "^29.7.0",
    "sass-loader": "^16.0.7",
    "style-loader": "^3.3.4",
    "svg-url-loader": "^7.1.1",
    "webpack": "^5.98.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^6.0.0"
  }
}
